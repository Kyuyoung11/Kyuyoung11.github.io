source "https://rubygems.org"

gem 'bundler'
gem 'jekyll', '~> 4.3'
gem 'jekyll-paginate'
# gem 'github-pages'  # Jekyll 3.9 고정 → Ruby 4.0 비호환, 로컬에서는 비활성화
gem 'jekyll-include-cache'

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]


gem "webrick", "~> 1.8"

# Ruby 4.0에서 표준 라이브러리에서 분리된 gem
gem "csv"
gem "base64"
gem "bigdecimal"
